TFBODE(num,den,w1,w2,npts)
BEGIN
  TFMAG(num,den,w1,w2,npts);
  TFPHASE(num,den,w1,w2,npts);
END;

TFPOLAR(num,den,w1,w2,npts)
BEGIN
  LOCAL dataxy,xv,yv;

  IF w1<=0 OR w2<=w1 THEN
    MSGBOX("Need 0 < wmin < wmax");
    RETURN;
  END;

  IF npts<20 THEN
    npts:=20;
  END;

  dataxy:=TFPOLARDATA(num,den,w1,w2,npts);
  xv:=dataxy(1);
  yv:=dataxy(2);

  TFDRAWCOMPLEX(xv,yv,"Polar Plot");
END;

TFNYQUISTCRIT(num,den)
BEGIN
  LOCAL poles,idx;
  LOCAL rp;
  LOCAL P,jwflag;
  LOCAL lines;

  P:=0;
  jwflag:=0;
  poles:=TFROOTSNUM(den);

  FOR idx FROM 1 TO SIZE(poles) DO
    rp:=RE(poles(idx));

    IF rp>1E-6 THEN
      P:=P+1;
    END;

    IF ABS(rp)<=1E-6 THEN
      jwflag:=1;
    END;
  END;

  lines:={};
  lines:=TFADDLINE(lines,"Open-loop RHP poles P = "+STRING(P));
  lines:=TFADDLINE(lines,"");
  lines:=TFADDLINE(lines,"Let N = clockwise encirclements");
  lines:=TFADDLINE(lines,"of the point (-1,0).");
  lines:=TFADDLINE(lines,"");
  lines:=TFADDLINE(lines,"Then Z = N + P");
  lines:=TFADDLINE(lines,"where Z = closed-loop RHP poles.");
  lines:=TFADDLINE(lines,"");
  lines:=TFADDLINE(lines,"Closed-loop stable if Z = 0.");

  IF jwflag==1 THEN
    lines:=TFADDLINE(lines,"");
    lines:=TFADDLINE(lines,"Warning: pole on imaginary axis.");
    lines:=TFADDLINE(lines,"Nyquist contour needs care.");
  END;

  TFSCROLLVIEW("NYQUIST CRITERION",lines);
END;
